# Copy this file to .env and fill in values. Never commit .env.

# Optional — Weights & Biases (https://wandb.ai → User settings → API keys)
WANDB_API_KEY=

# Optional — Slack Incoming Webhook (for drift alerts from GitHub Actions monitor.yml)
SLACK_WEBHOOK_URL=

# Optional — same names as GitHub Actions secrets for local parity
# GITHUB_TOKEN is only provided automatically in Actions; do not set locally for CLI.
